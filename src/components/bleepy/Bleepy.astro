    const currentMascotPersonaString = bleepyPersonaString; // Use direct Bleepy persona, sourced from correct import

    if (randomNumber < 0.7) { // 70% chance for legacy dialogue
      if (bleepyRandomDialogues && bleepyRandomDialogues.length > 0) { // Uses imported bleepyRandomDialogues
        const randomIndex = Math.floor(Math.random() * bleepyRandomDialogues.length);
        const selectedDialogue = bleepyRandomDialogues[randomIndex];
        displayEphemeralSpeech(selectedDialogue);
