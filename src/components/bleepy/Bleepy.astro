<!-- Main Mascot Container -->
<div id="mascot-container">
  <div id="mascot-visual-area">
    <!-- Mascot SVG will be injected here by JavaScript -->
  </div>


  <button id="dismiss-mascot-button" aria-label="Dismiss Mascot" title="Dismiss Mascot">
    🍴
  </button>

  <div id="mascot-dialogue">[Bleep] bloop! [Bleepy]'s online and ready to talk snacks!</div>
</div>

<!-- Spoon Icon Button to Bring Back Mascot -->
<button id="bring-back-mascot-button" style="display: none;" aria-label="Bring back mascot" title="Bring back mascot">
  🥄
</button>

<style>
  :root {
    /* Define your theme colors if not already global */
    --primary: #007bff;
    --primary-hover: #0056b3;
    --dialogue-bg-light: #e6f2ff;
    --dialogue-bg-dark: rgba(50, 50, 50, 0.9);
    --dialogue-text-dark: #f0f0f0;
    --dialogue-border-dark: rgba(65, 65, 65, 0.95);
  }

  #mascot-container {
    position: fixed;
    bottom: -250px; /* Start off-screen, increased height for potential taller mascots */
    right: 20px;
    background-color: transparent;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: bottom 0.7s ease-in-out;
    width: 200px; /* Adjusted width for potentially wider mascots */
    padding-top: 30px; /* Space for dismiss button */
    opacity: 0.85;
  }

  #mascot-container.visible {
    bottom: 20px; /* Final position */
  }

  #mascot-container.jiggle {
    animation: jiggle 0.5s ease-in-out;
  }

  @keyframes jiggle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-2px) rotate(-2deg); }
    50% { transform: translateY(0) rotate(2deg); }
    75% { transform: translateY(-1px) rotate(-1deg); }
  }

  /* NEW FADE OUT ANIMATION FOR VISUAL ONLY */
  @keyframes fadeOutMascotVisual {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  #mascot-visual-area.visual-fading-out {
    animation: fadeOutMascotVisual 1.5s ease-out forwards;
  }
  /* END NEW FADE OUT ANIMATION FOR VISUAL ONLY */

  #mascot-visual-area {
    width: 150px; /* Adjust as needed for new mascots */
    height: 180px; /* Adjust as needed */
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 10px;
  }

  #mascot-visual-area svg { /* Ensure SVGs scale nicely */
    max-width: 100%;
    max-height: 100%;
    animation: mascotWobble 3s infinite ease-in-out;
  }
  
  /* Base wobble for all mascots, can be overridden by specific mascot CSS */
  @keyframes mascotWobble {
    0%, 100% { transform: rotate(-1deg); }
    50% { transform: rotate(1deg); }
  }

  /* Dialogue Styling (similar to original, but positioned relative to new container) */
  #mascot-dialogue {
    position: absolute;
    bottom: 50%; /* Vertically centered relative to mascot-visual-area */
    right: 80%; /* Position to the left of mascot-visual-area */
    transform: translateY(50%) translateX(0px); /* Adjust Y for vertical centering, X for gap */
    width: 100px;
    padding: 8px 12px;
    background-color: var(--dialogue-bg-light);
    border: 1px solid var(--primary-hover);
    border-radius: 15px 15px 0 15px; /* Tail on bottom-right, pointing to mascot */
    box-shadow: -2px 2px 5px rgba(0,0,0,0.1); /* Shadow adjusted for left position */
    font-family: 'Comic Sans MS', 'Chalkboard SE', 'Marker Felt', sans-serif;
    font-size: 12px;
    color: var(--primary-hover);
    text-align: center;
    z-index: 1001;
    margin-right: 15px; /* Space between mascot and bubble */
    opacity: 1; /* Initial opacity for transition */
    transition: opacity 0.3s ease-in-out; /* Transition for smooth fade */
  }

  #mascot-dialogue::after {
    content: '';
    position: absolute;
    top: 50%; /* Align with middle of the bubble */
    left: 100%; /* Attach to the right side of the bubble */
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 10px 0 10px 10px; /* Triangle pointing right */
    border-color: transparent transparent transparent var(--dialogue-bg-light);
    filter: drop-shadow(1px 0px 0.5px rgba(0,0,0,0.1)); /* Shadow adjusted */
  }

  @media (prefers-color-scheme: dark) {
    #mascot-dialogue {
      background-color: var(--dialogue-bg-dark);
      color: var(--dialogue-text-dark);
      border: 1px solid var(--dialogue-border-dark);
    }
    #mascot-dialogue::after {
      border-color: transparent transparent transparent var(--dialogue-bg-dark);
      filter: drop-shadow(1px 0px 0.5px rgba(0,0,0,0.2)); /* Shadow adjusted */
    }
  }

  /* Dismiss Button (formerly kill-bleepy-icon-button) */
  #dismiss-mascot-button {
    position: absolute;
    top: 75px; /* Positioned within the mascot container at the top */
    right: 5px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    width: 30px; /* Adjusted for emoji */
    height: 30px; /* Adjusted for emoji */
    z-index: 1005;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px; /* Emoji size */
    font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji", sans-serif; /* Emoji font stack */
    line-height: 1; /* Helps center emoji */
    opacity: .75;
  }

  /* Spoon Icon Button */
  #bring-back-mascot-button {
    position: fixed;
    bottom: 10px;
    right: 170px;
    background-color: transparent;
    color: inherit; /* Let emoji use its natural color, or parent text color */
    border: none;
    border-radius: 0; /* No longer a circle if it's just the emoji */
    width: 35px;   /* Reduced size */
    height: 35px;  /* Reduced size */
    padding: 0;
    cursor: pointer;
    z-index: 999;
    box-shadow: none; /* Removed shadow */
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px; /* Reduced emoji size */
    font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
    transition: transform 0.2s ease-in-out;
    line-height: 1;
    opacity: 0.3;
  }
  #bring-back-mascot-button:hover {
    /* background-color: transparent; /* Keep transparent */
    transform: scale(1.15); /* Slightly larger scale for feedback */
    /* opacity: 0.8; /* Alternative subtle feedback */
  }



  /* Specific Mascot Styles (Example - can be extended) */
  .cuppy-cake-specific-styles .eyes { /* Example if Cuppy had unique eye CSS */
    /* ... */
  }
  /* Add more specific styles for Pretzel Pete, Sushi Sam if needed */

</style>

