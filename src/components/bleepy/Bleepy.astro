  // --- Core Functions ---
  function loadMascot(index: number) {
    if (!mascotVisualArea || index < 0 || index >= mascots.length) return;
    const mascot = mascots[index];
    mascotVisualArea.innerHTML = mascot.svgHTML;
    
    // Apply/remove specific CSS classes
    mascotVisualArea.className = ''; // Clear previous classes
    if (mascot.cssClasses) {
      mascotVisualArea.classList.add(mascot.cssClasses);
    }

    currentMascotIndex = index;
    // localStorage.setItem('lastSelectedMascot', mascot.name); // Removed: No longer storing last selected
    
    // if (cycleMascotNameButton) { // Removed: UI element is gone
    //     cycleMascotNameButton.textContent = mascot.name;
    // }

    // Clear previous special animation interval and start new one for the current mascot
    clearInterval(specialAnimationInterval as number);
    const currentMascotData = mascots[currentMascotIndex]; // Use a local var for clarity
    if (currentMascotData.uniqueAnimations && currentMascotData.uniqueAnimations.length > 0) {
      specialAnimationInterval = setInterval(tryPlayRandomMascotAnimation, 18000 + Math.random() * 5000); // e.g. 18-23 seconds
    }

    // Clear and set up surreal animation interval
    clearInterval(surrealAnimationInterval as number);
    if (currentMascotData.surrealAnimations && currentMascotData.surrealAnimations.length > 0) {
      // Surreal animations are much rarer: timer fires e.g. every 3-5 minutes
      // Actual play chance is then handled by tryPlaySurrealAnimation
      surrealAnimationInterval = setInterval(tryPlaySurrealAnimation, (3 * 60 * 1000) + Math.random() * (2 * 60 * 1000)); // 3 to 5 minutes
    }
    
    restartAnimationsAndDialogue();
  }

  function showMascot() {
    if (!mascotContainer || !bringBackButton || !mascotVisualArea) return;
    mascotContainer.style.display = 'flex'; // Make sure it's flex before animation
    mascotVisualArea.style.opacity = '1'; // Reset visual opacity
    mascotVisualArea.classList.remove('visual-fading-out'); // Ensure animation class is removed

    setTimeout(() => mascotContainer.classList.add('visible'), 50); // Delay for CSS transition
    bringBackButton.style.display = 'none';
    sessionStorage.removeItem('bleepyDismissed');
    sessionStorage.removeItem('lastSelectedMascot'); // Clear any old session storage for this

    // Randomly select a mascot
    const randomIndex = Math.floor(Math.random() * mascots.length);
    loadMascot(randomIndex);
    // showRandomCharacterSelectionUI(); // Removed: No character selection UI logic

    // Initial dialogue after being brought back
    // displayNewDialogue(false, "I'm back! Ready for more fun?");
  }

  function hideMascot(isDismissal = true) {
    if (!mascotContainer || !bringBackButton || !mascotVisualArea) return;

    if (isDismissal) {
      sessionStorage.setItem('bleepyDismissed', 'true');
      bringBackButton.style.display = 'flex'; // Show spoon
      displayNewDialogue(true); // Show dismissal message

      // Start fade-out animation for the visual element
      mascotVisualArea.classList.add('visual-fading-out');

      const onVisualFadeEnd = () => {
        // Visual fade ended. Ensure it's fully transparent.
        mascotVisualArea.style.opacity = '0';

        // Start timer for text to linger
        setTimeout(() => {
          // Linger timer ended. Hide the entire mascot container.
          if (sessionStorage.getItem('bleepyDismissed') === 'true') { // Check again
            mascotContainer.style.display = 'none';
          }
          mascotContainer.classList.remove('visible');   // Clean up visibility/positioning class
          mascotVisualArea.classList.remove('visual-fading-out'); // Clean up animation class for visual
          // Visual opacity will be reset by showMascot
        }, 1500); // Linger for 1.5 seconds
      };

      mascotVisualArea.addEventListener('animationend', onVisualFadeEnd, { once: true });

    } else { // Not a dismissal (e.g., initial load dismissed)
      mascotContainer.style.display = 'none'; // Hide immediately
      mascotContainer.classList.remove('visible'); // Ensure visible is also cleared
      mascotVisualArea.style.opacity = '0'; // Ensure visual is also hidden
    }
    clearTimers();
  }

  function clearTimers() {
    clearTimeout(inactivityTimer);
    clearTimeout(hoverTimeout);
    clearInterval(dialogueCycleInterval);
    clearInterval(specialAnimationInterval);
    clearInterval(surrealAnimationInterval);
  }

  function restartAnimationsAndDialogue() {
    if (!mascotContainer || !mascotDialogue) return;
    // Jiggle animation
    mascotContainer.classList.remove('jiggle');
    void mascotContainer.offsetWidth; // Trigger reflow
    mascotContainer.classList.add('jiggle');

    // Dialogue
    resetDialogueCycle();
  }
  
  // --- Dialogue Functions ---
  function getRandomDialogue(isDismissMsg = false) {
    const sourceArray = isDismissMsg ? dismissDialogues : dialogues;
    return sourceArray[Math.floor(Math.random() * sourceArray.length)];
  }

  function displayNewDialogue(isDismissMsg = false, customMessage: string | null = null) {
    if (!mascotDialogue || !mascotContainer?.classList.contains('visible')) return;

    const newText = customMessage ? customMessage : getRandomDialogue(isDismissMsg);

    // Fade out current text
    mascotDialogue.style.opacity = '0';

    setTimeout(() => {
      mascotDialogue.innerHTML = newText;
      // Fade in new text
      mascotDialogue.style.opacity = '1';

      // Re-trigger jiggle on dialogue change for emphasis
      if (mascotContainer) { // Ensure mascotContainer exists
        mascotContainer.classList.remove('jiggle');
        void mascotContainer.offsetWidth;
        mascotContainer.classList.add('jiggle');
      }
    }, 350); // Delay should be slightly longer than fade-out (0.3s)
  }
  
  function resetDialogueCycle() {
    clearTimers(); // Clear existing timers before starting new ones

    // Initial dialogue (can be a specific greeting or random)
    // displayNewDialogue(false, mascots[currentMascotIndex].name + " says hi!"); // Example specific greeting

    // Then, the explainer message
    hoverTimeout = setTimeout(() => {
      if (mascotContainer?.classList.contains('visible') && mascotDialogue) {
        mascotDialogue.innerHTML = "If it's your first time, check out this article: <a href='/posts/explainer/' style='color: inherit; text-decoration: underline;'>learn more here!</a>";
        mascotContainer.classList.remove('jiggle');
        void mascotContainer.offsetWidth;
        mascotContainer.classList.add('jiggle');
      }
    }, 7000); // Display after 7 seconds

    // Regular random dialogue cycle
    dialogueCycleInterval = setInterval(() => {
      if (mascotContainer?.classList.contains('visible')) {
        displayNewDialogue();
      }
    }, 45000); // Every 45 seconds

    // Reset inactivity timer for mouse/key interaction based dialogue
    resetInactivityBasedDialogueTimer();
  }

  function resetInactivityBasedDialogueTimer() {
    clearTimeout(inactivityTimer);
    inactivityTimer = setTimeout(() => {
      if (mascotContainer?.classList.contains('visible')) {
        displayNewDialogue();
      }
      resetInactivityBasedDialogueTimer(); // Keep the timer going
    }, 30000); // 30 seconds of inactivity
  }

  // --- New Mascot Animations Logic ---
  function playRandomMascotAnimation() {
    if (!mascotVisualArea || !mascotContainer?.classList.contains('visible')) return;

    const mascotData = mascots[currentMascotIndex];
    if (!mascotData.uniqueAnimations || mascotData.uniqueAnimations.length === 0) return;

    const availableAnimations = mascotData.uniqueAnimations;
    const animToPlay = availableAnimations[Math.floor(Math.random() * availableAnimations.length)];

    const targetElement = mascotVisualArea.querySelector(animToPlay.targetSelector) as SVGElement | null;

    if (targetElement && !targetElement.classList.contains(animToPlay.animationClass)) {
      // Basic check to prevent re-adding class if somehow already present (e.g. from a very fast previous trigger)
      // A more complex system could check for any active animation on the element.
      
      // Check if any animation from this mascot's unique set is already on this specific target.
      // This is to prevent, for example, left leg tapping if right leg is already tapping.
      // Or hat tipping if sprinkles are shivering (if both target the SVG root).
      let alreadyAnimating = false;
      if (targetElement.classList) {
        for (const anim of availableAnimations) {
            if (targetElement.classList.contains(anim.animationClass)) {
                alreadyAnimating = true;
                break;
            }
        }
      }
      // For elements that are not the SVG root, also check if SVG root has an animation class
      const svgRoot = mascotVisualArea.querySelector('svg');
      if (svgRoot && targetElement !== svgRoot) {
        for (const anim of availableAnimations) {
            // Check if the SVG root has an animation class that might conflict
            if (svgRoot.classList.contains(anim.animationClass) && anim.targetSelector === `svg#${svgRoot.id}` || anim.targetSelector === `svg.${svgRoot.classList[0]}`) {
                 // This logic is a bit broad, assumes targetSelector for root is specific.
                 // A simpler rule: if targetElement is not svgRoot, and svgRoot is animating, maybe skip.
                 // For now, the primary check is on targetElement itself.
            }
        }
      }


      if (alreadyAnimating) {
        // console.log(`Animation ${animToPlay.animationClass} skipped, ${animToPlay.targetSelector} already has a unique animation.`);
        return;
      }


      targetElement.classList.add(animToPlay.animationClass);

      const onAnimationEnd = (event: Event) => { // Use generic Event, or AnimationEvent if sure
        const currentTarget = event.currentTarget as HTMLElement;
        // Ensure the event is for the specific animation we added
        if (animToPlay.cssAnimationName && (event as AnimationEvent).animationName === animToPlay.cssAnimationName &&
            currentTarget.classList.contains(animToPlay.animationClass)) {
            currentTarget.classList.remove(animToPlay.animationClass);
        }
        // { once: true } handles removing this listener.
        // We still need to remove the 'animationcancel' listener if 'animationend' fires.
        currentTarget.removeEventListener('animationcancel', onAnimationCancel);
      };
      
      const onAnimationCancel = (event: Event) => { // Use generic Event, or AnimationEvent if sure
        const currentTarget = event.currentTarget as HTMLElement;
        // Ensure the event is for the specific animation we added
        if (animToPlay.cssAnimationName && (event as AnimationEvent).animationName === animToPlay.cssAnimationName &&
            currentTarget.classList.contains(animToPlay.animationClass)) {
            currentTarget.classList.remove(animToPlay.animationClass);
        }
        // { once: true } handles removing this listener.
        // We still need to remove the 'animationend' listener if 'animationcancel' fires.
        currentTarget.removeEventListener('animationend', onAnimationEnd);
      };

      targetElement.addEventListener('animationend', onAnimationEnd as EventListener, { once: true });
      targetElement.addEventListener('animationcancel', onAnimationCancel as EventListener, { once: true });
    }
  }

  function tryPlayRandomMascotAnimation() {
      // Chance to play an animation, e.g., 40%
      if (Math.random() < 0.4) {
          playRandomMascotAnimation();
      }
  }

  // --- Surreal Mascot Animations Logic ---
  function playSurrealAnimation() {
    if (!mascotVisualArea || !mascotContainer?.classList.contains('visible')) return;

    const mascotData = mascots[currentMascotIndex];
    if (!mascotData.surrealAnimations || mascotData.surrealAnimations.length === 0) return;

    // Assume one surreal animation per mascot for now, pick the first one
    const animData = mascotData.surrealAnimations[0] as SurrealAnimationData; // Cast to the union type
    const svgElement = mascotVisualArea.querySelector('svg');
    if (!svgElement) return;

    if (svgElement.dataset.surrealAnimationActive === 'true' || svgElement.dataset.uniqueAnimationActive === 'true') {
      // console.log("Surreal animation skipped, another animation is active.");
      return;
    }
    svgElement.dataset.surrealAnimationActive = 'true'; // Mark as active

    // Mascot-specific logic with type guards
    if (mascotData.name === "Cuppy Cake" && animData.id === "cc_eye_spy") {
      const specificAnimData = animData as CuppyCakeSurrealAnimation;
      const pupils = svgElement.querySelectorAll(specificAnimData.pupilSelector);
      const eyeGroup = svgElement.querySelector(specificAnimData.eyeGroupSelector) as HTMLElement | null;
      
      if (eyeGroup) eyeGroup.classList.add('animating-surreal'); // For overflow
      svgElement.classList.add(specificAnimData.animationClass);

      setTimeout(() => {
        svgElement.classList.remove(specificAnimData.animationClass);
        if (eyeGroup) eyeGroup.classList.remove('animating-surreal');
        delete svgElement.dataset.surrealAnimationActive;
      }, specificAnimData.duration);

    } else if (mascotData.name === "Pretzel Pete" && animData.id === "pp_unraveling") {
      const specificAnimData = animData as PretzelPeteSurrealAnimation;
      const originalBody = svgElement.querySelector(`#${specificAnimData.originalBodyId}`) as SVGPathElement | null;
      const unravelled1 = svgElement.querySelector(`#${specificAnimData.unravelledPathIds[0]}`) as SVGPathElement | null;
      const unravelled2 = svgElement.querySelector(`#${specificAnimData.unravelledPathIds[1]}`) as SVGPathElement | null;
      const saltCrystals = svgElement.querySelectorAll(specificAnimData.saltSelector);

      if (!originalBody || !unravelled1 || !unravelled2) {
        delete svgElement.dataset.surrealAnimationActive;
        return;
      }
      
      svgElement.classList.add(specificAnimData.animationClass);

      // Sequence:
      originalBody.style.opacity = '0';
      unravelled1.style.opacity = '1';
      saltCrystals.forEach(salt => {
        (salt as HTMLElement).classList.remove('reappearing');
        (salt as HTMLElement).classList.add('falling');
      });

      setTimeout(() => { // Step 1 done (original -> unravelled1)
        unravelled1.style.opacity = '0';
        unravelled2.style.opacity = '1';
        (unravelled2 as SVGPathElement).classList.add('swaying');

        setTimeout(() => { // Step 2 done (unravelled1 -> unravelled2, swaying starts)
          (unravelled2 as SVGPathElement).classList.remove('swaying');
          unravelled2.style.opacity = '0';
          unravelled1.style.opacity = '1';
          saltCrystals.forEach(salt => {
            (salt as HTMLElement).classList.remove('falling');
            (salt as HTMLElement).classList.add('reappearing');
          });

          setTimeout(() => { // Step 3 done (unravelled2 -> unravelled1, salt reappearing)
            unravelled1.style.opacity = '0';
            originalBody.style.opacity = '1';
            
            setTimeout(() => { // Step 4 done (unravelled1 -> original)
              saltCrystals.forEach(salt => (salt as HTMLElement).classList.remove('reappearing'));
              svgElement.classList.remove(specificAnimData.animationClass);
              delete svgElement.dataset.surrealAnimationActive;
            }, specificAnimData.saltFallDuration); // Ensure salt animation finishes

          }, specificAnimData.reverseStep1Duration);
        }, specificAnimData.swayDuration);
      }, specificAnimData.step2Duration);

    } else if (mascotData.name === "Sushi Sam" && animData.id === "ss_nori_void") {
      const specificAnimData = animData as SushiSamSurrealAnimation;
      const flap = svgElement.querySelector(specificAnimData.flapSelector) as SVGPathElement | null;
      if (!flap) {
        delete svgElement.dataset.surrealAnimationActive;
        return;
      }

      svgElement.classList.add(specificAnimData.animationClass); // This makes void layer visible
      flap.classList.add('opening');

      setTimeout(() => { // Flap is open
        flap.classList.remove('opening');
        // Void is visible, linger
        setTimeout(() => {
          flap.classList.add('closing');
          // Void layer will hide once parent class is removed
          setTimeout(() => { // Flap is closed
            flap.classList.remove('closing');
            svgElement.classList.remove(specificAnimData.animationClass);
            delete svgElement.dataset.surrealAnimationActive;
          }, specificAnimData.closeDuration);
        }, specificAnimData.revealDuration);
      }, specificAnimData.openDuration);
    } else {
      delete svgElement.dataset.surrealAnimationActive; // Unknown animation
    }
  }

  function tryPlaySurrealAnimation() {
    // Example: 5% chance when this (already infrequent) timer fires
    if (Math.random() < 0.05) {
      playSurrealAnimation();
    }
  }

  // --- Event Listeners ---
  function setupEventListeners() {
    if (!dismissButton || !bringBackButton || !mascotContainer) return; // Removed UI buttons from check

    dismissButton.addEventListener('click', () => {
      hideMascot(true);
    });

    bringBackButton.addEventListener('click', () => {
      showMascot();
    });

    // prevMascotButton, nextMascotButton, cycleMascotNameButton listeners removed
    
    // Inactivity and hover for dialogue
    window.addEventListener('mousemove', resetInactivityBasedDialogueTimer);
    window.addEventListener('keypress', resetInactivityBasedDialogueTimer);

    mascotContainer.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimeout); // Clear explainer/other timed messages
      hoverTimeout = setTimeout(() => {
        if (mascotContainer.classList.contains('visible')) {
          displayNewDialogue();
          resetInactivityBasedDialogueTimer(); 
        }
      }, 1500); // Dialogue on hover after 1.5s
    });

    mascotContainer.addEventListener('mouseleave', () => {
      clearTimeout(hoverTimeout);
    });
  }

  // --- Initialization ---
  function initializeMascotSystem() {
    if (sessionStorage.getItem('bleepyDismissed') === 'true') {
      hideMascot(false); // Hide immediately, don't show dismiss message
      if (bringBackButton) bringBackButton.style.display = 'flex'; // Ensure spoon is visible
      if (mascotContainer) mascotContainer.style.display = 'none';
      // if (characterSelectionUI) characterSelectionUI.style.display = 'none'; // Removed
    } else {
      // showMascot will now load a random mascot by default
      showMascot();
    }
    setupEventListeners();
  }

  // Wait for the DOM to be fully loaded before initializing
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeMascotSystem);
  } else {
    initializeMascotSystem(); // DOMContentLoaded has already fired
  }

</script>