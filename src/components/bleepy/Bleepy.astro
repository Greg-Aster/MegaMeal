    object-fit: contain;
  }
  
  /* Ephemeral Speech Styling */
  #mascot-ephemeral-speech {
    position: absolute;
    bottom: 79%; /* Adjust as needed based on visual area height */
    left: 50%;
    transform: translateX(-50%);
    width: auto;
    max-width: 85%; /* Or a suitable rem value */
    padding: 0.2rem 0.4rem;
    font-family: 'Comic Sans MS', 'Chalkboard SE', 'Marker Felt', sans-serif;
    font-size: clamp(0.8rem, 2.2vw, 0.95rem); /* Responsive font size */
    color: var(--primary-hover); /* Default light mode text color */
    text-align: center;
    z-index: 1001;
    opacity: 0;
    pointer-events: none;
    overflow-wrap: break-word;
  }

  @media (prefers-color-scheme: dark) {
    #mascot-ephemeral-speech {
      color: var(--dialogue-text-dark);
    }
  }

  #mascot-ephemeral-speech.appearing {
    animation: speech-appear 0.8s ease-out forwards;
  }

  #mascot-ephemeral-speech.fading {
    animation: speech-fade 1.2s ease-in forwards;
  }

  #mascot-ephemeral-speech.quick-fading {
    animation: speech-quick-fade 0.2s ease-in forwards;
  }

  @keyframes speech-appear {
    from { opacity: 0; transform: translate(-50%, 10px); } /* Start slightly lower */
    to { opacity: 1; transform: translate(-50%, 0); pointer-events: auto; }
  }

  @keyframes speech-fade {
    from { opacity: 1; transform: translate(-50%, 0); }
    to { opacity: 0; transform: translate(-50%, -10px); pointer-events: none; } /* Fade upwards */
  }

  @keyframes speech-quick-fade {
    from { opacity: 1; }
    to { opacity: 0; pointer-events: none; }
  }

  /* Old #mascot-dialogue styles removed or commented out if needed for reference */
  /*
  #mascot-dialogue { ... }
  */

  #mascot-chat-ui {
    display: flex;
    align-items: center; /* Vertically align items */
    width: 90%;
    margin: 0.5rem auto 0.25rem; /* Center horizontally, original vertical margins */
    gap: 0.5rem; /* Adjusted gap */
  }

  #mascot-chat-input {
    flex-grow: 1;
    min-width: 0; /* Allow input to shrink in flex layout */
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--primary-hover);
    border-radius: 0.3rem;
    font-family: 'Comic Sans MS', 'Chalkboard SE', 'Marker Felt', sans-serif;
