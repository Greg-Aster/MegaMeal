    }
  }
  @media (prefers-color-scheme: light) {
    :root {
      --speech-bubble-bg: var(--speech-bubble-bg-light);
      --speech-bubble-border: var(--speech-bubble-border-light);
      --speech-bubble-text: var(--speech-bubble-text-light);
    }
  }

  #mascot-container {
