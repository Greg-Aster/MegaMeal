  }

  /* Clearfix for the container if messages are floated */
  #mascot-container.is-banner-feature #chat-history-window::after {
    content: "";
    clear: both;
    display: table;
  }

  /* Dark mode considerations for chat messages if not covered by variables */
  @media (prefers-color-scheme: dark) {
    #mascot-container.is-banner-feature #chat-history-window .user-message {
      background-color: var(--primary-hover, #0056b3); /* Darker primary for user bg */
      /* color: white; remains good */
    }
    #mascot-container.is-banner-feature #chat-history-window .bleepy-message {
      background-color: var(--dialogue-bg-dark, rgba(50, 50, 50, 0.9)); /* Use existing dark variable */
      /* color: var(--dialogue-text-dark, #f0f0f0); inherited or set if needed */
    }
  }
  /* --- End Chat Message Styles --- */

</style>


<script>
  import {
    mascots,
    greetingMessages,
    randomDialogues,
    dismissDialogues,
    personaStrings,
    type MascotName,
    type SurrealAnimationData,
    type CuppyCakeSurrealAnimation,
    type PretzelPeteSurrealAnimation,
    type SushiSamSurrealAnimation
  } from './mascotData.ts';



  // --- DOM Elements ---
  const mascotContainer = document.getElementById('mascot-container');
  const mascotVisualArea = document.getElementById('mascot-visual-area');
  // const mascotDialogue = document.getElementById('mascot-dialogue'); // Old dialogue
  // const mascotEphemeralSpeech = document.getElementById('mascot-ephemeral-speech'); // Old ephemeral
  const mascotSpeechBubble = document.getElementById('mascot-speech-bubble');
  const mascotSpeechText = document.getElementById('mascot-speech-text');
  const dismissButton = document.getElementById('dismiss-mascot-button');
  const bringBackButton = document.getElementById('bring-back-mascot-button');
  const mascotChatInput = document.getElementById('mascot-chat-input') as HTMLInputElement;
  const mascotChatSendButton = document.getElementById('mascot-chat-send');

  // Mobile Function Card Elements
  const mobileMascotFunctionCard = document.getElementById('mobile-mascot-function-card');
  const mascotChatInputMobile = document.getElementById('mascot-chat-input-mobile') as HTMLInputElement;
  const mascotChatSendMobile = document.getElementById('mascot-chat-send-mobile');
  const dismissMascotButtonMobile = document.getElementById('dismiss-mascot-button-mobile');
  const bringBackMascotButtonMobile = document.getElementById('bring-back-mascot-button-mobile');
  const chatHistoryWindow = document.getElementById('chat-history-window');


  // --- State Variables ---
  let activeMascot: any; // Will hold the full mascot object from mascotData.ts
  let currentMascotIndex = 0;
  let inactivityTimer: NodeJS.Timeout | undefined;
  let hoverTimeout: NodeJS.Timeout | undefined;
  let dialogueCycleInterval: NodeJS.Timeout | number | undefined; // setInterval returns a number in browsers
  let specialAnimationInterval: NodeJS.Timeout | number | undefined;
  let surrealAnimationInterval: NodeJS.Timeout | number | undefined;
  let proactiveDialogueTimer: NodeJS.Timeout | undefined;
  let mouthOpenTimeout: NodeJS.Timeout | undefined;
  let randomExpressionTimeout: NodeJS.Timeout | undefined;
  
  interface ConversationEntry {
    sender: 'user' | 'bleepy';
    text: string;
  }
  let conversationHistory: ConversationEntry[] = [];


  // --- Core Functions ---
  function loadMascot(index: number) {
    if (!mascotVisualArea || index < 0 || index >= mascots.length) return;
    activeMascot = mascots[index];
    currentMascotIndex = index;
    conversationHistory = []; // Reset conversation history for new mascot

    const mascotImageDisplay = document.getElementById('mascot-image-display') as HTMLImageElement | null;
    mascotVisualArea.innerHTML = ''; // Clear previous content (SVG or old image if structure changes)

    if (activeMascot.type === "image-set") {
      if (mascotImageDisplay) {
        mascotImageDisplay.src = activeMascot.images.standard;
        mascotImageDisplay.style.display = 'block';
        mascotVisualArea.appendChild(mascotImageDisplay); // Ensure it's in the visual area
      }
    } else { // SVG type
      if (mascotImageDisplay) {
        mascotImageDisplay.style.display = 'none'; // Hide the static img tag
      }
      mascotVisualArea.innerHTML = activeMascot.svgHTML; // Inject SVG
    }
    
    // Apply/remove specific CSS classes to mascotVisualArea itself
    mascotVisualArea.className = ''; // Clear previous classes from the container
    if (activeMascot.cssClasses) {
      mascotVisualArea.classList.add(activeMascot.cssClasses);
    }

    // Clear previous animation intervals
    clearInterval(specialAnimationInterval as number);
    clearInterval(surrealAnimationInterval as number);

    // Conditionally set up animation intervals
    if (activeMascot.type !== "image-set") { // For SVG mascots
      if (activeMascot.uniqueAnimations && activeMascot.uniqueAnimations.length > 0) {
        specialAnimationInterval = setInterval(tryPlayRandomVisualEffect, 18000 + Math.random() * 5000);
      }
      if (activeMascot.surrealAnimations && activeMascot.surrealAnimations.length > 0) {
        surrealAnimationInterval = setInterval(tryPlaySurrealAnimation, (3 * 60 * 1000) + Math.random() * (2 * 60 * 1000));
      }
    } else { // For image-set mascots, we might have a different timer for expressions
        // The random image expression is now tied to tryPlayRandomVisualEffect
        specialAnimationInterval = setInterval(tryPlayRandomVisualEffect, 18000 + Math.random() * 5000);
    }
    
    restartAnimationsAndDialogue();
  }

  function showMascot() {
    if (!mascotContainer || !bringBackButton || !mascotVisualArea) return;
    mascotContainer.style.display = 'flex'; // Make sure it's flex before animation
    mascotVisualArea.style.opacity = '1'; // Reset visual opacity
    mascotVisualArea.classList.remove('visual-fading-out'); // Ensure animation class is removed

    setTimeout(() => {
      mascotContainer.classList.add('visible');
      startProactiveDialogueTimer(); // MOVED HERE: Restart proactive dialogue when mascot is shown
    }, 50); // Delay for CSS transition
    bringBackButton.style.display = 'none'; // Hide original bring back button
    sessionStorage.removeItem('bleepyDismissed');
    sessionStorage.removeItem('lastSelectedMascot'); // Clear any old session storage for this
    conversationHistory = []; // Reset conversation history when mascot is shown

    // Randomly select a mascot
    const randomIndex = Math.floor(Math.random() * mascots.length);
    loadMascot(randomIndex);

    // Mobile card state
    if (mobileMascotFunctionCard) {
      mobileMascotFunctionCard.classList.remove('mascot-dismissed-state');
      // The CSS for #mobile-mascot-function-card (not .mascot-dismissed-state)
      // should ensure the correct items are visible by default.
      // Specifically, #bring-back-mascot-button-mobile is display:none by default,
      // and others are display:flex (or whatever their default is).
    }
    // showRandomCharacterSelectionUI(); // Removed: No character selection UI logic

    // Initial dialogue after being brought back
    // displayNewDialogue(false, "I'm back! Ready for more fun?");
    // startProactiveDialogueTimer(); // OLD POSITION
  }

  function hideMascot(isDismissal = true) {
    if (!mascotContainer || !bringBackButton || !mascotVisualArea) return;

    if (isDismissal) {
      sessionStorage.setItem('bleepyDismissed', 'true');
      bringBackButton.style.display = 'flex'; // Show original spoon (will be hidden on mobile by CSS)

      // Mobile card state
      if (mobileMascotFunctionCard) {
        mobileMascotFunctionCard.classList.add('mascot-dismissed-state');
      }

      // displayNewDialogue(true); // Old dialogue system
      if (mascotSpeechBubble && mascotSpeechText && mascotSpeechText.textContent) {
        // If speech is visible, let it fade or quick-fade naturally
        // Or, force a quick fade if desired:
        // mascotSpeechBubble.className = 'quick-fading'; // Ensure this class is defined if used
        // setTimeout(() => { if(mascotSpeechText) mascotSpeechText.textContent = ''; }, 200);
      }


      // Start fade-out animation for the visual element
      mascotVisualArea.classList.add('visual-fading-out');

      const onVisualFadeEnd = () => {
        // Visual fade ended. Ensure it's fully transparent.
        mascotVisualArea.style.opacity = '0';

        // Start timer for text to linger
        setTimeout(() => {
          // Linger timer ended. Hide the entire mascot container.
          if (sessionStorage.getItem('bleepyDismissed') === 'true') { // Check again
            mascotContainer.style.display = 'none';
          }
          mascotContainer.classList.remove('visible');   // Clean up visibility/positioning class
          mascotVisualArea.classList.remove('visual-fading-out'); // Clean up animation class for visual
          // Visual opacity will be reset by showMascot
        }, 1500); // Linger for 1.5 seconds
      };

      mascotVisualArea.addEventListener('animationend', onVisualFadeEnd, { once: true });

    } else { // Not a dismissal (e.g., initial load dismissed)
      mascotContainer.style.display = 'none'; // Hide immediately
      mascotContainer.classList.remove('visible'); // Ensure visible is also cleared
      mascotVisualArea.style.opacity = '0'; // Ensure visual is also hidden
      // Mobile card state for initial hide
      if (mobileMascotFunctionCard) {
        mobileMascotFunctionCard.classList.add('mascot-dismissed-state');
      }
    }
    clearTimers(); // This will now also clear proactiveDialogueTimer
  }

  function clearTimers() {
    clearTimeout(inactivityTimer);
    clearTimeout(hoverTimeout);
    clearInterval(dialogueCycleInterval);
    clearInterval(specialAnimationInterval);
    clearInterval(surrealAnimationInterval);
    clearTimeout(proactiveDialogueTimer);
  }

  function restartAnimationsAndDialogue() {
    if (!mascotContainer) return; // Removed mascotDialogue check
    // Jiggle animation
    mascotContainer.classList.remove('jiggle');
    void mascotContainer.offsetWidth; // Trigger reflow
    mascotContainer.classList.add('jiggle');

    // Dialogue - ephemeral speech will handle its own clearing
    // if (mascotDialogue) mascotDialogue.innerHTML = '';
  }
  
  // --- Chat History Logic ---
  function addMessageToHistory(text: string, sender: 'user' | 'bleepy') {
    if (!chatHistoryWindow) return; // Should only be called if chatHistoryWindow exists (i.e., in banner mode)

    const messageElement = document.createElement('div');
    messageElement.classList.add('chat-message');
    messageElement.classList.add(sender === 'user' ? 'user-message' : 'bleepy-message');
    
    const senderName = sender === 'user' ? 'You' : (activeMascot?.name || 'Bleepy');
    const senderPrefix = document.createElement('strong');
    senderPrefix.textContent = `${senderName}: `;
    
    const textNode = document.createTextNode(text); // Use createTextNode for plain text

    messageElement.appendChild(senderPrefix);
    messageElement.appendChild(textNode);
    
    chatHistoryWindow.appendChild(messageElement);
    
    // Add to internal conversation history
    conversationHistory.push({ sender, text });

    // Auto-scroll to the bottom
    chatHistoryWindow.scrollTop = chatHistoryWindow.scrollHeight;
  }

  // --- Ephemeral Speech Logic ---
  let speechLingerTimeout: NodeJS.Timeout | undefined;
  let speechFadeCleanupListener: ((event: AnimationEvent) => void) | undefined;
  let speechQuickFadeTimeout: NodeJS.Timeout | undefined;

  function displayEphemeralSpeech(text: string) {
    const mascotContainer = document.getElementById('mascot-container');
    const isBannerMode = mascotContainer && mascotContainer.classList.contains('is-banner-feature');

    // --- Mascot jiggle/mouth animation logic (can run for both modes if Bleepy is speaking) ---
    const mascotImageDisplay = document.getElementById('mascot-image-display') as HTMLImageElement | null;
    if (activeMascot && mascotImageDisplay) {
      if (activeMascot.type === "image-set") {
        if (activeMascot.images.openmouth) {
          clearTimeout(mouthOpenTimeout);
          mascotImageDisplay.src = activeMascot.images.openmouth;
          mouthOpenTimeout = setTimeout(() => {
            if (activeMascot && activeMascot.images.standard && mascotImageDisplay) {
               mascotImageDisplay.src = activeMascot.images.standard;
            }
          }, 700);
        }
        // Jiggle for image-set mascot (only if not already handled by a specific expression animation)
        if (!mascotImageDisplay.classList.contains('wiggling')) { // Avoid double jiggle
           mascotImageDisplay.classList.remove('jiggle'); // Ensure clean state
           void mascotImageDisplay.offsetWidth;
           mascotImageDisplay.classList.add('jiggle');
           setTimeout(() => { if (mascotImageDisplay) mascotImageDisplay.classList.remove('jiggle'); }, 500);
        }
      } else { // SVG mascot
        const svgElement = mascotVisualArea?.querySelector('svg');
        if (svgElement) {
          svgElement.classList.remove('jiggle');
          void (svgElement as unknown as HTMLElement).offsetWidth;
          svgElement.classList.add('jiggle');
          setTimeout(() => { svgElement.classList.remove('jiggle'); }, 500);
        }
      }
    }
    // --- End of jiggle/mouth animation logic ---

    if (isBannerMode) {
      // If in banner mode, add Bleepy's reply to the history window.
      // The single speech bubble is hidden by CSS in banner mode.
      // The addMessageToHistory function will also add it to the conversationHistory array.
      addMessageToHistory(text, 'bleepy');
      return; // Done for banner mode, no ephemeral speech bubble logic needed.
    }

    // --- Existing logic for overlay mode (single speech bubble) ---
    if (!mascotSpeechBubble || !mascotSpeechText) return; // Check for overlay elements

    clearTimeout(speechLingerTimeout);
    speechLingerTimeout = undefined;
    if (speechFadeCleanupListener) {
      mascotSpeechBubble.removeEventListener('animationend', speechFadeCleanupListener);
      speechFadeCleanupListener = undefined;
    }
    mascotSpeechBubble.className = '';
    mascotSpeechBubble.style.opacity = '0';
    mascotSpeechBubble.style.transform = 'translateY(0)';
    mascotSpeechBubble.style.pointerEvents = 'none';
    mascotSpeechText.textContent = '';

    mascotSpeechText.textContent = text;
    void mascotSpeechBubble.offsetWidth;
    mascotSpeechBubble.classList.add('appearing');

    const onAppearAnimationEnd = (event: AnimationEvent) => {
      if (event.animationName !== 'speech-appear') return;
      const words = text.split(/\s+/).length;
      let currentLingerDuration = (words / 2.5) * 1000 + 1500;
      currentLingerDuration = Math.max(2500, Math.min(currentLingerDuration, 10000));
      speechLingerTimeout = setTimeout(() => {
        if (!mascotSpeechBubble || !mascotSpeechText) return;
        mascotSpeechBubble.classList.remove('appearing');
        mascotSpeechBubble.classList.add('fading');
        speechFadeCleanupListener = (fadeEvent: AnimationEvent) => {
          if (fadeEvent.animationName !== 'speech-fade') return;
          if (!mascotSpeechBubble || !mascotSpeechText) return;
          mascotSpeechBubble.classList.remove('fading');
          mascotSpeechText.textContent = '';
          mascotSpeechBubble.style.opacity = '0';
          mascotSpeechBubble.style.pointerEvents = 'none';
          speechFadeCleanupListener = undefined;
        };
        mascotSpeechBubble.addEventListener('animationend', speechFadeCleanupListener as EventListener, { once: true });
      }, currentLingerDuration);
    };
    mascotSpeechBubble.addEventListener('animationend', onAppearAnimationEnd as EventListener, { once: true });
    // --- End of existing overlay mode logic ---
  }


  // --- Old Dialogue Functions (to be removed or adapted) ---
  /*
  function getRandomDialogue(isDismissMsg = false) { ... }
  function displayNewDialogue(isDismissMsg = false, customMessage: string | null = null) { ... }
  function resetDialogueCycle() { ... }
  */

  function resetInactivityBasedDialogueTimer() {
    // clearTimeout(inactivityTimer);
    // Inactivity timer might not be relevant with active chat, or could trigger a "Still there?" message.
    // For now, disabling it to prevent interference with chat.
  }


  // --- Chat Logic ---
  async function handleSendMessage() {
    let currentInput: HTMLInputElement | null = null;
    let userMessage: string = "";
    const isMobileView = mobileMascotFunctionCard && getComputedStyle(mobileMascotFunctionCard).display !== 'none';

    if (isMobileView && mascotChatInputMobile) {
      currentInput = mascotChatInputMobile;
    } else if (mascotChatInput) {
      currentInput = mascotChatInput;
    }

    if (!currentInput) {
      console.warn("handleSendMessage: No valid input field found.");
      return;
    }
    userMessage = currentInput.value.trim();
    if (!userMessage) return;

    const mascotContainer = document.getElementById('mascot-container');
    const isBannerMode = mascotContainer && mascotContainer.classList.contains('is-banner-feature');

    if (isBannerMode && chatHistoryWindow) { // Check chatHistoryWindow exists
      addMessageToHistory(userMessage, 'user'); // Add user's message to history
    }
    
    // The rest of the function remains the same:
    // (Ensure speech bubble elements are available for overlay mode - this check might need adjustment
    // if mascotSpeechBubble is null in banner mode, but displayEphemeralSpeech handles that)
    if (!isBannerMode && (!mascotSpeechBubble || !mascotSpeechText)) { // Check for overlay elements only if not banner mode
        console.warn("handleSendMessage: Speech bubble elements not found for overlay mode.");
        // return; // Decide if this should be a hard stop for overlay mode
    }

    const currentMascot = mascots[currentMascotIndex];
    const currentMascotName = currentMascot.name as MascotName;
    const currentMascotPersonaString = personaStrings[currentMascotName] || "You are a friendly mascot.";
    const pageCtx = getPageContextForBleepy();
    let promptForWorker: string;

    // Format conversation history for the prompt
    let historyString = "Previous Conversation (if any):\n";
    if (conversationHistory.length > 0) {
      historyString += conversationHistory.map(entry => `${entry.sender === 'user' ? 'User' : activeMascot?.name || 'Bleepy'}: ${entry.text}`).join('\n') + '\n\n';
    } else {
      historyString = ""; // No history yet
    }

    let contextString = "";
    if (pageCtx) {
      contextString = `Current Page Context:\n- Title: ${pageCtx.title || "N/A"}\n- Description: ${pageCtx.description || "N/A"}\n- Tags: ${(pageCtx.tags && pageCtx.tags.length > 0 ? pageCtx.tags.join(', ') : "N/A")}\n- Category: ${pageCtx.category || "N/A"}\n- Timeline Era: ${pageCtx.timelineEra || "N/A"}\n- Timeline Location: ${pageCtx.timelineLocation || "N/A"}\n- Author's Hint for Mascot: ${pageCtx.mascotContext || "N/A"}\n\n`;
    }

    promptForWorker = `${historyString}${contextString}Based on the page context (if provided), your persona, AND the previous conversation (if any), respond to the following user message:\nUser: "${userMessage}"`;
    
    currentInput.value = '';
    resetProactiveDialogueTimer();

    const workerUrl = 'https://my-mascot-worker-service.greggles.workers.dev';
    try {
      const response = await fetch(workerUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: promptForWorker,
          persona: currentMascotPersonaString
        })
      });
      const data = await response.json();
      if (response.ok && data.reply) {
        // For overlay mode, Bleepy's reply also needs to be added to conversationHistory.
        // For banner mode, displayEphemeralSpeech calls addMessageToHistory which handles it.
        if (!isBannerMode) {
          conversationHistory.push({ sender: 'bleepy', text: data.reply });
        }
        displayEphemeralSpeech(data.reply);
      } else {
        const errorMessage = data.error || 'Failed to get a response.';
        if (!isBannerMode) {
           // Log error to history if not banner (banner mode logs via displayEphemeralSpeech -> addMessageToHistory)
          conversationHistory.push({ sender: 'bleepy', text: errorMessage });
        }
        displayEphemeralSpeech(errorMessage);
      }
    } catch (error) {
      const connectErrorMessage = 'Could not connect to the mascot.';
      if (!isBannerMode) {
        conversationHistory.push({ sender: 'bleepy', text: connectErrorMessage });
      }
      displayEphemeralSpeech(connectErrorMessage);
      console.error('Error calling mascot worker:', error);
    }
  }

  // --- Page Context Logic ---
  function getPageContextForBleepy() {
    const contextDiv = document.getElementById('bleepy-page-context');
    if (contextDiv) {
      const contextData = contextDiv.dataset.context;
      if (contextData) {
        try {
          const parsedContext = JSON.parse(contextData);
          return parsedContext;
        } catch (e) {
          console.error("Bleepy: Error parsing page context JSON:", e);
          return null;
        }
      }
    }
    return null;
  }
  
  // --- Proactive Dialogue Logic ---
  function triggerProactiveDialogue() {
    if (!mascotContainer?.classList.contains('visible')) {
      // If mascot is not visible, don't trigger.
      // The timer will be restarted by showMascot if/when it's reshown,
      // or cleared by hideMascot if dismissed.
      return;
    }

    const randomNumber = Math.random();
    const currentMascot = mascots[currentMascotIndex];
    const currentMascotName = currentMascot.name as MascotName;
    const currentMascotPersonaString = personaStrings[currentMascotName] || "You are a friendly mascot.";

    if (randomNumber < 0.7) { // 70% chance for legacy dialogue
      if (randomDialogues && randomDialogues.length > 0) {
        const randomIndex = Math.floor(Math.random() * randomDialogues.length);
        const selectedDialogue = randomDialogues[randomIndex];
        displayEphemeralSpeech(selectedDialogue);
      } else {
        // Fallback if randomDialogues is empty
        displayEphemeralSpeech("...");
      }
    } else { // 30% chance for AI-generated thought
      const pageContext = getPageContextForBleepy();
      let thoughtInstruction = "";
  
      // Chance to play random image expression if mascot is image-set
      // This is handled by tryPlayRandomVisualEffect called by specialAnimationInterval
      // The prompt for triggerProactiveDialogue was: "Modify or create a function like playRandomImageExpression(). This function, when called (e.g., by the existing proactive animation timer..."
      // So, it's not directly part of this text-dialogue triggering.

      if (pageContext) {
        // Construct Contextual Prompt
        const pageMascotContext = pageContext.mascotContext || "N/A";
        const pageTitle = pageContext.title || "N/A";
        const pageDescription = pageContext.description || "N/A";
        const pageTags = (pageContext.tags && pageContext.tags.length > 0 ? pageContext.tags.join(', ') : "N/A");
        const pageCategory = pageContext.category || "N/A";
        const pageTimelineEra = pageContext.timelineEra || "N/A";
        const pageTimelineLocation = pageContext.timelineLocation || "N/A";

        thoughtInstruction = `You are ${currentMascotName}.

Your primary goal for this random thought is to reflect the SPECIFIC content of the current webpage.

**Key Focus for This Thought:**
- Specific Page Context for ${currentMascotName}: ${pageMascotContext}

Supporting Page Details:
- Title: ${pageTitle}
- Description: ${pageDescription}
- Tags: ${pageTags}
- Category: ${pageCategory}
- Timeline Era: ${pageTimelineEra}
- Timeline Location: ${pageTimelineLocation}

Instruction:
Generate a brief, spontaneous, in-character statement, observation, or dark joke.
1.  **Prioritize**: Your thought MUST be directly and obviously inspired by the "**Key Focus for This Thought**" (${pageMascotContext}) if it is not "N/A". Make a clear connection.
2.  **Fallback**: If "${pageMascotContext}" is "N/A", then draw your inspiration primarily from the "Supporting Page Details" (especially Title and Description).
3.  **Style**: Maintain your ${currentMascotName} persona (as fully defined in the system prompt sent separately by the worker). The thought should be a random musing, not a reply to a user. Keep it concise.`;

      } else {
        // Construct Generic/Default Prompt
        thoughtInstruction = `You are ${currentMascotName}. Generate a brief, spontaneous, in-character statement, observation, or dark joke, consistent with your established persona (which is provided as a system instruction). This is not a reply to a user, but rather a random thought or musing. Keep it concise.`;
      }
      
      displayEphemeralSpeech("Mascot is pondering..."); // Loading state

      const workerUrl = 'https://my-mascot-worker-service.greggles.workers.dev';
      fetch(workerUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: thoughtInstruction,
          persona: currentMascotPersonaString
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.reply) {
          displayEphemeralSpeech(data.reply);
        } else {
          console.error('Proactive AI thought error:', data.error || 'No reply from worker');
          // Fallback for AI failure
          if (randomDialogues && randomDialogues.length > 0) {
            const randomIndex = Math.floor(Math.random() * randomDialogues.length);
            const fallbackPhrase = randomDialogues[randomIndex];
            displayEphemeralSpeech(fallbackPhrase);
          } else {
            displayEphemeralSpeech("Hmm...");
          }
        }
      })
      .catch(error => {
        console.error('Error calling mascot worker for proactive thought:', error);
         if (randomDialogues && randomDialogues.length > 0) {
            const randomIndex = Math.floor(Math.random() * randomDialogues.length);
            const fallbackPhrase = randomDialogues[randomIndex];
            displayEphemeralSpeech(fallbackPhrase);
          } else {
            displayEphemeralSpeech("My thoughts are tangled!");
          }
      });
    }
    // Restart the timer for the next proactive dialogue
    startProactiveDialogueTimer();
  }

  function startProactiveDialogueTimer() {
    clearTimeout(proactiveDialogueTimer);
    if (!mascotContainer?.classList.contains('visible')) {
      // Don't start the timer if the mascot is hidden.
      // It will be started by showMascot when mascot becomes visible.
      return;
    }
    const randomDelay = Math.random() * (60000 - 45000) + 45000; // 45-60 seconds
    proactiveDialogueTimer = setTimeout(triggerProactiveDialogue, randomDelay);
  }

  function resetProactiveDialogueTimer() {
    // This will clear the existing timer and start a new one.
    // Ensures that user interaction or mascot recall resets the countdown.
    startProactiveDialogueTimer();
  }

  // --- New Mascot Animations Logic ---
  function playRandomImageExpression() {
    const mascotImageDisplay = document.getElementById('mascot-image-display') as HTMLImageElement | null;
    if (!activeMascot || activeMascot.type !== "image-set" || !mascotImageDisplay || !activeMascot.images) {
      return;
    }

    const expressionKeys = Object.keys(activeMascot.images).filter(
      key => key !== "standard" && key !== "openmouth"
    );

    if (expressionKeys.length === 0) return;

    const randomKey = expressionKeys[Math.floor(Math.random() * expressionKeys.length)];
    mascotImageDisplay.src = activeMascot.images[randomKey];

    clearTimeout(randomExpressionTimeout);
    randomExpressionTimeout = setTimeout(() => {
      if (activeMascot && activeMascot.images.standard && mascotImageDisplay) {
        mascotImageDisplay.src = activeMascot.images.standard;
      }
    }, Math.random() * 500 + 1000); // 1000ms to 1500ms
  }

  function playRandomMascotAnimation() { // This is for SVG animations
    if (!mascotVisualArea || !mascotContainer?.classList.contains('visible')) return;
    if (!activeMascot || activeMascot.type === "image-set") return; // Guard for SVG type

    const mascotData = activeMascot; // Use activeMascot
    if (!mascotData.uniqueAnimations || mascotData.uniqueAnimations.length === 0) return;

    const availableAnimations = mascotData.uniqueAnimations;
    const animToPlay = availableAnimations[Math.floor(Math.random() * availableAnimations.length)];

    const targetElement = mascotVisualArea.querySelector(animToPlay.targetSelector) as SVGElement | null;

    if (targetElement && !targetElement.classList.contains(animToPlay.animationClass)) {
      // Basic check to prevent re-adding class if somehow already present (e.g. from a very fast previous trigger)
      // A more complex system could check for any active animation on the element.
      
      // Check if any animation from this mascot's unique set is already on this specific target.
      // This is to prevent, for example, left leg tapping if right leg is already tapping.
      // Or hat tipping if sprinkles are shivering (if both target the SVG root).
      let alreadyAnimating = false;
      if (targetElement.classList) {
        for (const anim of availableAnimations) {
            if (targetElement.classList.contains(anim.animationClass)) {
                alreadyAnimating = true;
                break;
            }
        }
      }
      // For elements that are not the SVG root, also check if SVG root has an animation class
      const svgRoot = mascotVisualArea.querySelector('svg');
      if (svgRoot && targetElement !== svgRoot) {
        for (const anim of availableAnimations) {
            // Check if the SVG root has an animation class that might conflict
            if (svgRoot.classList.contains(anim.animationClass) && anim.targetSelector === `svg#${svgRoot.id}` || anim.targetSelector === `svg.${svgRoot.classList[0]}`) {
                 // This logic is a bit broad, assumes targetSelector for root is specific.
                 // A simpler rule: if targetElement is not svgRoot, and svgRoot is animating, maybe skip.
                 // For now, the primary check is on targetElement itself.
            }
        }
      }


      if (alreadyAnimating) {
        // console.log(`Animation ${animToPlay.animationClass} skipped, ${animToPlay.targetSelector} already has a unique animation.`);
        return;
      }


      targetElement.classList.add(animToPlay.animationClass);

      const onAnimationEnd = (event: Event) => { // Use generic Event, or AnimationEvent if sure
        const currentTarget = event.currentTarget as HTMLElement;
        // Ensure the event is for the specific animation we added
        if (animToPlay.cssAnimationName && (event as AnimationEvent).animationName === animToPlay.cssAnimationName &&
            currentTarget.classList.contains(animToPlay.animationClass)) {
            currentTarget.classList.remove(animToPlay.animationClass);
        }
        // { once: true } handles removing this listener.
        // We still need to remove the 'animationcancel' listener if 'animationend' fires.
        currentTarget.removeEventListener('animationcancel', onAnimationCancel);
      };
      
      const onAnimationCancel = (event: Event) => { // Use generic Event, or AnimationEvent if sure
        const currentTarget = event.currentTarget as HTMLElement;
        // Ensure the event is for the specific animation we added
        if (animToPlay.cssAnimationName && (event as AnimationEvent).animationName === animToPlay.cssAnimationName &&
            currentTarget.classList.contains(animToPlay.animationClass)) {
            currentTarget.classList.remove(animToPlay.animationClass);
        }
        // { once: true } handles removing this listener.
        // We still need to remove the 'animationend' listener if 'animationcancel' fires.
        currentTarget.removeEventListener('animationend', onAnimationEnd);
      };

      targetElement.addEventListener('animationend', onAnimationEnd as EventListener, { once: true });
      targetElement.addEventListener('animationcancel', onAnimationCancel as EventListener, { once: true });
    }
  }

  function tryPlayRandomVisualEffect() { // Called by specialAnimationInterval
    const isBanner = mascotContainer?.classList.contains('is-banner-feature');
    if (!activeMascot || (!isBanner && !mascotContainer?.classList.contains('visible'))) return;

    if (activeMascot.type === "image-set") {
      const mascotImageEl = document.getElementById('mascot-image-display') as HTMLImageElement | null;
      if (!mascotImageEl) return;

      const randomNumber = Math.random();

      if (randomNumber < 0.4) { // 40% chance to wiggle
        mascotImageEl.classList.add('wiggling');
        mascotImageEl.addEventListener('animationend', () => {
          mascotImageEl.classList.remove('wiggling');
        }, { once: true });
      } else if (randomNumber < 0.8) { // 40% chance for random expression
        // The playRandomImageExpression function already checks if expressions exist
        playRandomImageExpression();
      }
      // Else (20% chance): do nothing for this cycle
    } else { // SVG type
      if (activeMascot.uniqueAnimations && activeMascot.uniqueAnimations.length > 0) {
        if (Math.random() < 0.4) { // Chance to play SVG animation
           playRandomMascotAnimation(); // Original function for SVG parts
        }
      }
    }
  }

  // --- Surreal Mascot Animations Logic ---
  function playSurrealAnimation() {
    if (!activeMascot || activeMascot.type === "image-set" || !mascotVisualArea || !mascotContainer?.classList.contains('visible')) {
      return; // Do not run for image-set mascots or if not visible/active
    }

    // const mascotData = mascots[currentMascotIndex]; // Now use activeMascot
    if (!activeMascot.surrealAnimations || activeMascot.surrealAnimations.length === 0) return;

    // Assume one surreal animation per mascot for now, pick the first one
    const animData = activeMascot.surrealAnimations[0] as SurrealAnimationData; // Cast to the union type
    const svgElement = mascotVisualArea.querySelector('svg');
    if (!svgElement) return;

    if (svgElement.dataset.surrealAnimationActive === 'true' || svgElement.dataset.uniqueAnimationActive === 'true') {
      // console.log("Surreal animation skipped, another animation is active.");
      return;
    }
    svgElement.dataset.surrealAnimationActive = 'true'; // Mark as active

    // Mascot-specific logic with type guards
    // Note: "Cuppy Cake" is now "BLEEPY" and is image-set, so this block won't run for BLEEPY.
    // This logic remains for other potential SVG mascots.
    if (activeMascot.name === "Cuppy Cake" && animData.id === "cc_eye_spy") { // This name might be outdated if BLEEPY was Cuppy
      const specificAnimData = animData as CuppyCakeSurrealAnimation;
      const pupils = svgElement.querySelectorAll(specificAnimData.pupilSelector);
      const eyeGroup = svgElement.querySelector(specificAnimData.eyeGroupSelector) as HTMLElement | null;
      
      if (eyeGroup) eyeGroup.classList.add('animating-surreal'); // For overflow
      svgElement.classList.add(specificAnimData.animationClass);

      setTimeout(() => {
        svgElement.classList.remove(specificAnimData.animationClass);
        if (eyeGroup) eyeGroup.classList.remove('animating-surreal');
        delete svgElement.dataset.surrealAnimationActive;
      }, specificAnimData.duration);

    } else if (activeMascot.name === "Pretzel Pete" && animData.id === "pp_unraveling") {
      const specificAnimData = animData as PretzelPeteSurrealAnimation;
      const originalBody = svgElement.querySelector(`#${specificAnimData.originalBodyId}`) as SVGPathElement | null;
      const unravelled1 = svgElement.querySelector(`#${specificAnimData.unravelledPathIds[0]}`) as SVGPathElement | null;
      const unravelled2 = svgElement.querySelector(`#${specificAnimData.unravelledPathIds[1]}`) as SVGPathElement | null;
      const saltCrystals = svgElement.querySelectorAll(specificAnimData.saltSelector);

      if (!originalBody || !unravelled1 || !unravelled2) {
        delete svgElement.dataset.surrealAnimationActive;
        return;
      }
      
      svgElement.classList.add(specificAnimData.animationClass);

      // Sequence:
      originalBody.style.opacity = '0';
      unravelled1.style.opacity = '1';
      saltCrystals.forEach(salt => {
        (salt as HTMLElement).classList.remove('reappearing');
        (salt as HTMLElement).classList.add('falling');
      });

      setTimeout(() => { // Step 1 done (original -> unravelled1)
        unravelled1.style.opacity = '0';
        unravelled2.style.opacity = '1';
        (unravelled2 as SVGPathElement).classList.add('swaying');

        setTimeout(() => { // Step 2 done (unravelled1 -> unravelled2, swaying starts)
          (unravelled2 as SVGPathElement).classList.remove('swaying');
          unravelled2.style.opacity = '0';
          unravelled1.style.opacity = '1';
          saltCrystals.forEach(salt => {
            (salt as HTMLElement).classList.remove('falling');
            (salt as HTMLElement).classList.add('reappearing');
          });

          setTimeout(() => { // Step 3 done (unravelled2 -> unravelled1, salt reappearing)
            unravelled1.style.opacity = '0';
            originalBody.style.opacity = '1';
            
            setTimeout(() => { // Step 4 done (unravelled1 -> original)
              saltCrystals.forEach(salt => (salt as HTMLElement).classList.remove('reappearing'));
              svgElement.classList.remove(specificAnimData.animationClass);
              delete svgElement.dataset.surrealAnimationActive;
            }, specificAnimData.saltFallDuration); // Ensure salt animation finishes

          }, specificAnimData.reverseStep1Duration);
        }, specificAnimData.swayDuration);
      }, specificAnimData.step2Duration);

    } else if (activeMascot.name === "Sushi Sam" && animData.id === "ss_nori_void") {
      const specificAnimData = animData as SushiSamSurrealAnimation;
      const flap = svgElement.querySelector(specificAnimData.flapSelector) as SVGPathElement | null;
      if (!flap) {
        delete svgElement.dataset.surrealAnimationActive;
        return;
      }

      svgElement.classList.add(specificAnimData.animationClass); // This makes void layer visible
      flap.classList.add('opening');

      setTimeout(() => { // Flap is open
        flap.classList.remove('opening');
        // Void is visible, linger
        setTimeout(() => {
          flap.classList.add('closing');
          // Void layer will hide once parent class is removed
          setTimeout(() => { // Flap is closed
            flap.classList.remove('closing');
            svgElement.classList.remove(specificAnimData.animationClass);
            delete svgElement.dataset.surrealAnimationActive;
          }, specificAnimData.closeDuration);
        }, specificAnimData.revealDuration);
      }, specificAnimData.openDuration);
    } else {
      delete svgElement.dataset.surrealAnimationActive; // Unknown animation
    }
  }

  function tryPlaySurrealAnimation() {
    // Example: 5% chance when this (already infrequent) timer fires
    if (Math.random() < 0.05) {
      playSurrealAnimation();
    }
  }

  // --- Event Listeners ---
  function setupEventListeners() {
    if (!dismissButton || !bringBackButton || !mascotContainer || !mascotChatSendButton || !mascotChatInput) return;

    dismissButton.addEventListener('click', () => {
      clearTimeout(proactiveDialogueTimer); // Clear timer on dismiss
      if (dismissDialogues && dismissDialogues.length > 0) {
        const dismissalMessage = dismissDialogues[Math.floor(Math.random() * dismissDialogues.length)];
        displayEphemeralSpeech(dismissalMessage);
      } else {
      }
      hideMascot(true);
    });

    bringBackButton.addEventListener('click', () => {
      showMascot();
    });

    mascotChatSendButton.addEventListener('click', handleSendMessage);
    mascotChatInput.addEventListener('keypress', (event) => {
      if (event.key === 'Enter') {
        handleSendMessage(); // handleSendMessage already calls resetProactiveDialogueTimer
      }
    });

    // Mobile Function Card Event Listeners
    if (mascotChatInputMobile) {
      mascotChatInputMobile.addEventListener('keypress', (event) => {
        if (event.key === 'Enter') {
          handleSendMessage(); // handleSendMessage is now aware of mobile/desktop inputs
        }
      });
    }
    if (mascotChatSendMobile) {
      mascotChatSendMobile.addEventListener('click', handleSendMessage);
    }
    if (dismissMascotButtonMobile) {
      dismissMascotButtonMobile.addEventListener('click', () => {
        clearTimeout(proactiveDialogueTimer);
        if (dismissDialogues && dismissDialogues.length > 0) {
          const dismissalMessage = dismissDialogues[Math.floor(Math.random() * dismissDialogues.length)];
          displayEphemeralSpeech(dismissalMessage);
        }
        hideMascot(true);
      });
    }
    if (bringBackMascotButtonMobile) {
      bringBackMascotButtonMobile.addEventListener('click', showMascot);
    }
    
    // Inactivity and hover for dialogue - potentially remove or adapt for chat
    // window.addEventListener('mousemove', resetInactivityBasedDialogueTimer);
    // window.addEventListener('keypress', resetInactivityBasedDialogueTimer);

    // mascotContainer.addEventListener('mouseenter', () => {
    //   clearTimeout(hoverTimeout); // Clear explainer/other timed messages
    //   hoverTimeout = setTimeout(() => {
    //     if (mascotContainer.classList.contains('visible')) {
    //       // displayNewDialogue(); // Don't show random dialogue if chat is active
    //       // resetInactivityBasedDialogueTimer();
    //     }
    //   }, 1500);
    // });

    // mascotContainer.addEventListener('mouseleave', () => {
    //   clearTimeout(hoverTimeout);
    // });
  }

  // --- Initialization ---
  function initializeMascotSystem() {
    const mascotContainer = document.getElementById('mascot-container'); // Ensure this is accessible
    if (!mascotContainer) return;

    const parentElement = mascotContainer.parentElement;
    const isBannerMode = parentElement && parentElement.classList.contains('assistant-banner-content');

    if (isBannerMode) {
      mascotContainer.classList.add('is-banner-feature');
      // Ensure Bleepy is visible and styled for banner mode
      mascotContainer.style.display = 'flex'; // Or 'block', depending on your flex setup
      mascotContainer.classList.remove('visible'); // Remove this if it triggers fixed-position animations
      
      // Potentially bypass fixed-overlay specific logic:
      // For example, directly load a mascot without the slide-in animation or session checks.
      const randomIndex = Math.floor(Math.random() * mascots.length);
      loadMascot(randomIndex); // Load mascot (this will reset conversationHistory)
      startProactiveDialogueTimer(); // Start dialogue timer
      // Skip the sessionStorage check and hideMascot/showMascot calls for fixed overlay
      setupEventListeners(); // Still setup event listeners, though some might be N/A
      return; // Exit early to prevent fixed-overlay logic from running
    }

    // --- Existing logic for fixed overlay ---
    if (sessionStorage.getItem('bleepyDismissed') === 'true') {
      hideMascot(false);
      if (bringBackButton) bringBackButton.style.display = 'flex';
      if (mascotContainer) mascotContainer.style.display = 'none';
    } else {
      showMascot();
    }
    setupEventListeners();
    // --- End of existing logic ---
  }

  document.addEventListener('astro:page-load', () => {
    const mobileCard = document.getElementById('mobile-mascot-function-card');
    if (mobileCard) {
    } else {
      console.error("Mobile card #mobile-mascot-function-card NOT FOUND in DOM for logging.");
    }

    const desktopChatUi = document.getElementById('mascot-chat-ui'); // Assuming this is the ID of the original desktop chat UI wrapper
    if (desktopChatUi) {
    } else {
      console.error("Desktop #mascot-chat-ui NOT FOUND in DOM for logging.");
    }
  });

  // Wait for the DOM to be fully loaded before initializing
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeMascotSystem);
  } else {
    initializeMascotSystem(); // DOMContentLoaded has already fired
  }

</script>